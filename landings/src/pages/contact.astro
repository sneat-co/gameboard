---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — GameBoard.live"
  description="Get in touch with the GameBoard.live team about early access, clubs and tournaments."
>
  <section class="section">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>Let's talk game day</h1>
        <p>
          Questions about early access, running a tournament, or a club rollout?
          Send us a message and we'll get back to you.
        </p>
        <p>
          Or email us directly at
          <a href="mailto:hello@gameboard.live">hello@gameboard.live</a>.
        </p>
      </div>

      <!-- Placeholder form: does not submit anywhere yet. -->
      <form class="contact-form" onsubmit="return false;" aria-label="Contact form">
        <label>
          Name
          <input name="name" type="text" autocomplete="name" required />
        </label>
        <label>
          Email
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          Message
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn btn-primary">Send message</button>
        <p class="form-note">This form is a placeholder and doesn't send yet.</p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-4);
    align-items: start;
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3rem);
  }
  .contact-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-3);
    display: grid;
    gap: var(--space-2);
  }
  label {
    display: grid;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  input,
  textarea {
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font: inherit;
    font-weight: 500;
  }
  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .form-note {
    font-size: 0.8rem;
    margin: 0;
  }

  @media (min-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
