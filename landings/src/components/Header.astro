---
const links = [
  { href: "/features", label: "Features" },
  { href: "/pricing", label: "Pricing" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label="GameBoard.live home">
      <span class="dot"></span>
      GameBoard<span class="tld">.live</span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {
          links.map((l) => (
            <li>
              <a href={l.href} aria-current={path === l.href ? "page" : undefined}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a href="/#early-access" class="btn btn-primary header-cta">Join early access</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 64px;
  }
  .brand {
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .brand:hover {
    text-decoration: none;
  }
  .tld {
    color: var(--color-accent-text);
  }
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent);
  }
  nav {
    margin-left: auto;
  }
  nav ul {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--color-text-muted);
    font-weight: 600;
  }
  nav a:hover,
  nav a[aria-current="page"] {
    color: var(--color-text);
    text-decoration: none;
  }
  .header-cta {
    padding: 0.55rem 1.1rem;
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    nav {
      display: none;
    }
  }
</style>
